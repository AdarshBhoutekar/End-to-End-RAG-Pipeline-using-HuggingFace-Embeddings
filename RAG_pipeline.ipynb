    "from langchain_groq import ChatGroq\n",
    "\n",
    "groq_llm = ChatGroq(\n",
    "    groq_api_key = API_KEY_GROQ,\n",
    "    model = \"qwen/qwen3-32b\",\n",
    "    temperature = 0.1,\n",
    "    max_tokens = 1024\n",
    ")"
