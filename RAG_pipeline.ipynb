    "def generate_output_groq( query, rag_retriever, llm, top_k = 3):\n",
    "    results = rag_retriever.retreive(query, top_k)\n",
    "\n",
    "    context = \"\\n\".join(doc[\"document\"] for doc in results) if results else \"\"\n",
    "\n",
    "    if not context:\n",
    "        print(\"We found no relevant context for the given query\")\n",
    "\n",
    "    # Context +  Query\n",
    "    prompt = f\"\"\" use given context to generate the answer for the \n",
    "    Context : {context}\n",
    "    Query : {query} \"\"\"\n",
    "\n",
    "    response = llm.invoke([prompt.format(context=context, query=query)]) # Expecting a string as a prompt\n",
    "\n",
    "    return response.content\n",
    "    "
   ]
